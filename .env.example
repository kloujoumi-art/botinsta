# ============================================================
#  BotInsta - Configuration
# ============================================================

# --- Identifiants Instagram ---
INSTAGRAM_USERNAME=votre_username
INSTAGRAM_PASSWORD=votre_mot_de_passe

# --- Comptes cibles (séparés par des virgules, sans @) ---
TARGET_ACCOUNTS=compte_concurrent1,compte_concurrent2,compte_concurrent3

# --- Navigateur ---
# false = avec fenêtre (recommandé au début), true = sans fenêtre
HEADLESS=false

# --- Limites journalières (CONSERVER CES VALEURS BASSES pour la sécurité) ---
MAX_FOLLOWS_PER_DAY=25
MAX_LIKES_PER_DAY=40
MAX_PROFILE_VISITS_PER_DAY=80
MAX_STORIES_PER_DAY=50
MAX_REELS_PER_DAY=30

# --- Délais entre actions (en secondes) ---
MIN_ACTION_DELAY=4
MAX_ACTION_DELAY=12

# --- Durée de session (en secondes) ---
MIN_SESSION_DURATION=1800
MAX_SESSION_DURATION=3600

# --- Proxy (optionnel, laisser vide si inutilisé) ---
PROXY_URL=

# --- Dashboard ---
DASHBOARD_PORT=5000
DASHBOARD_HOST=127.0.0.1

# --- Logs ---
LOG_LEVEL=INFO
LOG_FILE=./data/botinsta.log
